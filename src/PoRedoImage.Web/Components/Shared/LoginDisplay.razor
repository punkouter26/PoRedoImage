<AuthorizeView>
    <Authorized>
        <div class="d-flex align-items-center gap-2 ms-3">
            <span class="app-nav__user text-truncate" style="max-width:180px" title="@context.User.Identity?.Name">
                <i class="bi bi-person-circle me-1"></i>@context.User.Identity?.Name
            </span>
            <a href="/logout" class="app-nav__link">
                <i class="bi bi-box-arrow-right me-1"></i>Sign out
            </a>
        </div>
    </Authorized>
    <NotAuthorized>
        <a href="/login" class="app-nav__link ms-3">
            <i class="bi bi-person me-1"></i>Sign in
        </a>
    </NotAuthorized>
</AuthorizeView>

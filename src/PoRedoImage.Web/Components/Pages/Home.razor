@page "/"
@rendermode InteractiveServer

<PageTitle>PoRedoImage — AI Image Studio</PageTitle>

<div class="container py-4">
    <div class="hero-section text-center mb-5">
        <div class="hero-icon mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="url(#grad1)" stroke-width="1.5">
                <defs>
                    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" style="stop-color:#052767" />
                        <stop offset="100%" style="stop-color:#3a0647" />
                    </linearGradient>
                </defs>
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z" />
            </svg>
        </div>
        <h1 class="hero-title">AI Image Studio</h1>
        <p class="hero-subtitle">Choose a feature below to reimagine your photos with the power of AI.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10 col-md-12">
            <div class="feature-selector">

                <a href="/image-regeneration" class="feature-card">
                    <div class="feature-card__icon"><i class="bi bi-palette2"></i></div>
                    <div class="feature-card__title">Image Regeneration</div>
                    <div class="feature-card__desc">AI creates a new artistic interpretation of your photo using DALL-E 3</div>
                    <div class="feature-card__cta">Get started <i class="bi bi-arrow-right ms-1"></i></div>
                </a>

                <a href="/meme-generation" class="feature-card">
                    <div class="feature-card__icon"><i class="bi bi-emoji-laughing"></i></div>
                    <div class="feature-card__title">Meme Generation</div>
                    <div class="feature-card__desc">AI writes a witty caption and overlays it on your image instantly</div>
                    <div class="feature-card__cta">Get started <i class="bi bi-arrow-right ms-1"></i></div>
                </a>

                <a href="/bulk-generate" class="feature-card">
                    <div class="feature-card__icon"><i class="bi bi-images"></i></div>
                    <div class="feature-card__title">Bulk Generate</div>
                    <div class="feature-card__desc">Generate 10 artistic style variations of your image from curated prompts</div>
                    <div class="feature-card__cta">Get started <i class="bi bi-arrow-right ms-1"></i></div>
                </a>

            </div>
        </div>
    </div>
</div>
